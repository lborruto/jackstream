# Port the addon listens on
PORT=7000

# TMDB metadata cache TTL in minutes (default: 24h)
CACHE_TTL_MINUTES=1440

# Timeout for external HTTP calls (Jackett, TMDB) in ms
REQUEST_TIMEOUT_MS=8000

# MB to download before starting the HTTP stream
STREAM_READY_MB=5

# Max seconds to wait for STREAM_READY_MB before returning 503
STREAM_READY_TIMEOUT_S=60

# Idle minutes before stopping a torrent
TORRENT_IDLE_TIMEOUT_MIN=30

# production | development
NODE_ENV=production
