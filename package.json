{
  "name": "jackstream",
  "version": "1.0.0",
  "description": "Self-hosted Stremio addon — query your Jackett and stream torrents instantly via WebTorrent.",
  "type": "module",
  "main": "src/addon.js",
  "scripts": {
    "start": "node src/addon.js",
    "dev": "node --watch src/addon.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "lint": "eslint \"src/**/*.js\" \"tests/**/*.js\"",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\" \"public/**/*.html\""
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "stremio-addon-sdk": "^1.6.10",
    "webtorrent": "^2.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.15.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.0"
  },
  "license": "MIT"
}
